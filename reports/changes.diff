--- /home/user/pristine/tmp_find_matching_window.py	1970-01-01 00:00:00.000000000 +0000
+++ /home/user/work/tmp_find_matching_window.py	2026-07-18 11:23:40.620270486 +0000
@@ -0,0 +1,107 @@
+from __future__ import annotations
+import csv, zipfile, urllib.request, logging, json, math
+from datetime import datetime, timezone
+from pathlib import Path
+import pandas as pd
+
+logging.disable(logging.CRITICAL)
+
+from twa.config import Settings
+from twa.models.types import Candle, Timeframe, RegimeLabel
+import twa.backtest.replay as replay
+import twa.signal.engine as sig_engine
+import twa.regime.classifier as regime_mod
+
+DATA_DIR = Path('/home/user/data/binance_months')
+DATA_DIR.mkdir(parents=True, exist_ok=True)
+months=['2025-04','2025-05','2025-06','2025-07','2025-08']
+
+all_candles=[]
+for month in months:
+    path=DATA_DIR/f'BTCUSDT-1h-{month}.zip'
+    if not path.exists():
+        urllib.request.urlretrieve(f'https://data.binance.vision/data/futures/um/monthly/klines/BTCUSDT/1h/BTCUSDT-1h-{month}.zip', path)
+    with zipfile.ZipFile(path) as z:
+        with z.open(z.namelist()[0]) as f:
+            reader=csv.DictReader((line.decode() for line in f))
+            for row in reader:
+                ot=datetime.fromtimestamp(int(row['open_time'])/1000,tz=timezone.utc)
+                ct=datetime.fromtimestamp(int(row['close_time'])/1000,tz=timezone.utc)
+                all_candles.append(Candle(symbol='BTCUSDT',exchange='binance',timeframe=Timeframe.H1,open_time=ot,close_time=ct,open=float(row['open']),high=float(row['high']),low=float(row['low']),close=float(row['close']),volume=float(row['volume'])))
+all_candles=sorted(all_candles,key=lambda c:c.open_time)
+
+
+def simple_clip_normalise(name: str, raw: float) -> float:
+    if raw is None or (isinstance(raw, float) and math.isnan(raw)):
+        return 0.0
+    return float(max(-1.0, min(1.0, float(raw))))
+
+def old_classify(features, cfg=None):
+    ret=float(features.get('log_return_16',0.0))
+    return RegimeLabel.TREND_UP if ret>=0 else RegimeLabel.TREND_DOWN
+
+def old_reg_conf(features, regime, cfg=None):
+    ret=abs(float(features.get('log_return_16',0.0)))
+    trend=abs(float(features.get('trend_strength_48',0.0)))
+    return float(min(0.95, max(0.10, 0.45+8.0*ret+0.25*trend)))
+
+
+def run_window(candles, mode='current'):
+    orig_norm=sig_engine.normalise_factor
+    orig_classify_replay=replay.classify
+    orig_regconf_replay=replay.regime_confidence
+    orig_classify=regime_mod.classify
+    orig_regconf=regime_mod.regime_confidence
+    traces=[]
+    orig_compute_signal=replay.compute_signal
+    def rec_compute(candles, timeframe, factor_overrides, regime, regime_conf, cfg=sig_engine.DEFAULT_CFG, news_dampen=1.0, ml_calibration=1.0):
+        sig=orig_compute_signal(candles, timeframe, factor_overrides, regime, regime_conf, cfg=cfg, news_dampen=news_dampen, ml_calibration=ml_calibration)
+        if sig is not None:
+            traces.append({'time': candles[-1].open_time.isoformat(), 'entry_state': getattr(sig.entry_state,'value',None)})
+        return sig
+    cfg=sig_engine.DEFAULT_CFG
+    try:
+        if mode=='rr':
+            cfg=sig_engine.EngineConfig(**{**sig_engine.DEFAULT_CFG.__dict__, 'risk_reward_targets': (1.0,2.0,3.0)})
+        elif mode=='norm':
+            sig_engine.normalise_factor=simple_clip_normalise
+        elif mode=='regime':
+            regime_mod.classify=old_classify; replay.classify=old_classify
+            regime_mod.regime_confidence=old_reg_conf; replay.regime_confidence=old_reg_conf
+        replay.compute_signal=rec_compute
+        result=replay.simulate(candles, Timeframe.H1, factor_overrides_list=[{}]*len(candles), settings=Settings(_env_file=None, risk_cooldown_s=0), cfg=cfg)
+    finally:
+        sig_engine.normalise_factor=orig_norm
+        regime_mod.classify=orig_classify; replay.classify=orig_classify_replay
+        regime_mod.regime_confidence=orig_regconf; replay.regime_confidence=orig_regconf_replay
+        replay.compute_signal=orig_compute_signal
+    closed=[t.pnl_bps for t in result.trades if t.exit_price is not None]
+    s=pd.Series(closed,dtype=float)
+    trace_map={x['time']:x for x in traces}
+    enter=wait=0; enter_closed=[]; wait_closed=[]
+    for t in result.trades:
+        st=trace_map.get(t.entry_time.isoformat(),{}).get('entry_state','unknown')
+        if st=='wait':
+            wait+=1; wait_closed.append(t.pnl_bps)
+        else:
+            enter+=1; enter_closed.append(t.pnl_bps)
+    return {
+        'trades':result.total_trades,
+        'edge':float(result.expectancy_bps),
+        'hit_rate_actual':float((s>0).mean()) if len(s) else 0.0,
+        'enter_trades':enter,
+        'enter_hit':float((pd.Series(enter_closed)>0).mean()) if enter_closed else 0.0,
+        'wait_trades':wait,
+        'wait_hit':float((pd.Series(wait_closed)>0).mean()) if wait_closed else 0.0,
+    }
+
+candidates=[]
+for start in range(0, len(all_candles)-720, 12):
+    window=all_candles[start:start+720]
+    cur=run_window(window,'current')
+    score=abs(cur['trades']-76)+100*abs(cur['hit_rate_actual']-0.184)+20*abs(cur['enter_trades']-69)+100*abs(cur['enter_hit']-0.203)+20*abs(cur['wait_trades']-7)+100*abs(cur['wait_hit']-0.0)
+    candidates.append({'start':start,'start_time':window[0].open_time.isoformat(),'end_time':window[-1].open_time.isoformat(),'score':score, **cur})
+
+candidates=sorted(candidates,key=lambda x:x['score'])[:10]
+Path('/home/user/work/tmp_matching_windows.json').write_text(json.dumps(candidates, indent=2), encoding='utf-8')
+print('done')
