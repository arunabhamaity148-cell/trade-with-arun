+from __future__ import annotations
+import csv, zipfile, json, logging, urllib.request
+from datetime import datetime, timezone
+from pathlib import Path
+import copy
+import pandas as pd
+
+logging.disable(logging.CRITICAL)
+
+from twa.config import Settings
+from twa.models.types import Candle, Timeframe, RegimeLabel
+import twa.backtest.replay as replay
+import twa.regime.classifier as regime_mod
+from twa.research.utils import max_drawdown, sharpe_like
+
+MONTH='2025-05'
+DATA_DIR=Path('/home/user/data/binance_months')
+path=DATA_DIR/f'BTCUSDT-1h-{MONTH}.zip'
+if not path.exists():
+    urllib.request.urlretrieve(f'https://data.binance.vision/data/futures/um/monthly/klines/BTCUSDT/1h/BTCUSDT-1h-{MONTH}.zip', path)
+
+candles=[]
+with zipfile.ZipFile(path) as z:
+    with z.open(z.namelist()[0]) as f:
+        reader=csv.DictReader((line.decode() for line in f))
+        for row in reader:
+            ot=datetime.fromtimestamp(int(row['open_time'])/1000,tz=timezone.utc)
+            ct=datetime.fromtimestamp(int(row['close_time'])/1000,tz=timezone.utc)
+            candles.append(Candle(symbol='BTCUSDT',exchange='binance',timeframe=Timeframe.H1,open_time=ot,close_time=ct,open=float(row['open']),high=float(row['high']),low=float(row['low']),close=float(row['close']),volume=float(row['volume'])))
+candles=candles[:720]
+
+orig_weights=copy.deepcopy(regime_mod.FACTOR_WEIGHTS)
+orig_norm=copy.deepcopy(regime_mod.WEIGHTS_NORMALISED)
+
+def renorm(d):
+    s=sum(abs(v) for v in d.values())
+    return {k:v/s for k,v in d.items()}
+
+variants={}
+variants['current']=copy.deepcopy(orig_weights)
+
+v=copy.deepcopy(orig_weights)
+for k in ['trend_strength_48','log_return_16','obv_slope_48','obi']:
+    v[RegimeLabel.TREND_DOWN][k]=abs(v[RegimeLabel.TREND_DOWN][k])
+variants['trend_down_sign_fix']=v
+
+v2=copy.deepcopy(v)
+v2[RegimeLabel.STRESSED].update({
+    'trend_strength_48':0.15,
+    'log_return_16':0.10,
+    'obv_slope_48':0.05,
+    'obi':0.05,
+    'realised_vol_30':-0.10,
+    'volume_zscore_96':0.05,
+    'funding':0.0,'basis':0.0,'oi_delta':0.0,
+})
+variants['trend_down_plus_stressed_dir']=v2
+
+v3=copy.deepcopy(v2)
+v3[RegimeLabel.VOLATILE].update({
+    'trend_strength_48':0.20,
+    'log_return_16':0.10,
+    'obv_slope_48':0.10,
+    'obi':0.10,
+    'volume_zscore_96':0.10,
+    'realised_vol_30':-0.05,
+    'funding':0.0,'basis':0.0,'oi_delta':0.0,
+})
+variants['all_dir_fallback']=v3
+
+rows=[]
+for name, weights in variants.items():
+    regime_mod.FACTOR_WEIGHTS.clear(); regime_mod.FACTOR_WEIGHTS.update(weights)
+    regime_mod.WEIGHTS_NORMALISED.clear(); regime_mod.WEIGHTS_NORMALISED.update({r:renorm(w) for r,w in weights.items()})
+    result=replay.simulate(candles, Timeframe.H1, factor_overrides_list=[{}]*len(candles), settings=Settings(_env_file=None, risk_cooldown_s=0))
+    closed=[t.pnl_bps for t in result.trades if t.exit_price is not None]
+    ser=pd.Series(closed,dtype=float)
+    rows.append({'name':name,'trades':result.total_trades,'edge':float(result.expectancy_bps),'hit_rate':float(result.win_rate() or 0.0),'drawdown':float(abs(max_drawdown(ser))) if len(ser) else 0.0,'sharpe':sharpe_like(ser)})
+
+# restore
+regime_mod.FACTOR_WEIGHTS.clear(); regime_mod.FACTOR_WEIGHTS.update(orig_weights)
+regime_mod.WEIGHTS_NORMALISED.clear(); regime_mod.WEIGHTS_NORMALISED.update(orig_norm)
+Path('/home/user/work/tmp_weight_fix_test.json').write_text(json.dumps(rows, indent=2), encoding='utf-8')
+print('done')
