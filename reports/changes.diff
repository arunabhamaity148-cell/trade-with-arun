+    return {k:v/s for k,v in d.items()}
+
+variants={}
+variants['current']=copy.deepcopy(orig_weights)
+
+v=copy.deepcopy(orig_weights)
+for regime in v:
+    v[regime]['volume_zscore_96']=0.0
+    v[regime]['realised_vol_30']=0.0
+for k in ['trend_strength_48','log_return_16','obv_slope_48','obi']:
