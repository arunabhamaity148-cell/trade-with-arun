+from __future__ import annotations
+import csv, zipfile, math, json
+from datetime import datetime, timezone
+from pathlib import Path
+from typing import List, Dict, Callable
+import pandas as pd
+
+from twa.config import Settings
+from twa.models.types import Candle, Timeframe, RegimeLabel
+import twa.backtest.replay as replay
+import twa.signal.engine as sig_engine
+import twa.regime.classifier as regime_mod
+from twa.features.engineering import compute_all
+from twa.research.utils import max_drawdown, sharpe_like
+
+ZIP = Path('/home/user/data/BTCUSDT-1h-2026-06.zip')
+
+
+def load_candles() -> List[Candle]:
+    out = []
+    with zipfile.ZipFile(ZIP) as z:
+        name = z.namelist()[0]
+        with z.open(name) as f:
+            reader = csv.DictReader((line.decode() for line in f))
+            for row in reader:
+                ot = datetime.fromtimestamp(int(row['open_time'])/1000, tz=timezone.utc)
+                ct = datetime.fromtimestamp(int(row['close_time'])/1000, tz=timezone.utc)
+                out.append(Candle(symbol='BTCUSDT', exchange='binance', timeframe=Timeframe.H1,
+                                  open_time=ot, close_time=ct,
+                                  open=float(row['open']), high=float(row['high']),
+                                  low=float(row['low']), close=float(row['close']), volume=float(row['volume'])))
+    return out
+
+
+def simple_clip_normalise(name: str, raw: float) -> float:
+    if raw is None or (isinstance(raw, float) and math.isnan(raw)):
+        return 0.0
+    return float(max(-1.0, min(1.0, float(raw))))
+
+
+def old_classify(features: Dict[str, float], cfg=None) -> RegimeLabel:
+    ret = float(features.get('log_return_16', 0.0))
+    return RegimeLabel.TREND_UP if ret >= 0 else RegimeLabel.TREND_DOWN
+
+
+def old_regime_confidence(features: Dict[str, float], regime: RegimeLabel, cfg=None) -> float:
+    ret = abs(float(features.get('log_return_16', 0.0)))
+    trend = abs(float(features.get('trend_strength_48', 0.0)))
+    score = min(0.95, max(0.10, 0.45 + 8.0 * ret + 0.25 * trend))
+    return float(score)
+
+
+def evaluate(name: str, *, cfg=None, normaliser=None, classifier=None, reg_conf=None):
+    candles = load_candles()
+    orig_norm = sig_engine.normalise_factor
+    orig_classify_replay = replay.classify
+    orig_regconf_replay = replay.regime_confidence
+    orig_classify = regime_mod.classify
+    orig_regconf = regime_mod.regime_confidence
+    traces=[]
+
+    def recording_compute_signal(candles, timeframe, factor_overrides, regime, regime_conf, cfg= sig_engine.DEFAULT_CFG, news_dampen=1.0, ml_calibration=1.0):
+        sig = orig_compute_signal(candles, timeframe, factor_overrides, regime, regime_conf, cfg=cfg, news_dampen=news_dampen, ml_calibration=ml_calibration)
+        if sig is not None:
+            traces.append({
+                'open_time': candles[-1].open_time.isoformat(),
+                'entry_state': getattr(sig.entry_state, 'value', None),
+                'side': sig.side.value,
+                'regime': sig.regime.value,
+                'raw_conf': sig.raw_confidence,
+            })
+        return sig
+    orig_compute_signal = replay.compute_signal
+    try:
