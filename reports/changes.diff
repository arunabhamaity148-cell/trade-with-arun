+            sig_engine.normalise_factor = normaliser
+        if classifier is not None:
+            regime_mod.classify = classifier
+            replay.classify = classifier
+        if reg_conf is not None:
+            regime_mod.regime_confidence = reg_conf
+            replay.regime_confidence = reg_conf
+        replay.compute_signal = recording_compute_signal
+        result = replay.simulate(candles, Timeframe.H1, factor_overrides_list=[{}]*len(candles), settings=Settings(_env_file=None, risk_cooldown_s=0), cfg=cfg or sig_engine.DEFAULT_CFG)
+    finally:
+        sig_engine.normalise_factor = orig_norm
+        regime_mod.classify = orig_classify
+        replay.classify = orig_classify_replay
+        regime_mod.regime_confidence = orig_regconf
+        replay.regime_confidence = orig_regconf_replay
+        replay.compute_signal = orig_compute_signal
+    closed = [t.pnl_bps for t in result.trades if t.exit_price is not None]
+    series = pd.Series(closed, dtype=float)
+    trace_map = {x['open_time']: x for x in traces}
+    enter_now=wait=0
+    enter_now_closed=[]
+    wait_closed=[]
+    for t in result.trades:
+        tr = trace_map.get(t.entry_time.isoformat())
+        st = tr['entry_state'] if tr else 'unknown'
+        if st == 'wait':
+            wait += 1
+            if t.exit_price is not None: wait_closed.append(t.pnl_bps)
+        else:
+            enter_now += 1
+            if t.exit_price is not None: enter_now_closed.append(t.pnl_bps)
+    summary = {
+        'name': name,
+        'trades': result.total_trades,
+        'edge_per_trade_bps': float(result.expectancy_bps),
+        'hit_rate': float(result.win_rate() or 0.0),
+        'drawdown_bps': float(abs(max_drawdown(series))) if len(series) else 0.0,
+        'sharpe_like': sharpe_like(series),
+        'enter_now_trades': enter_now,
+        'enter_now_hit_rate': float((pd.Series(enter_now_closed)>0).mean()) if len(enter_now_closed)>=1 else 0.0,
+        'wait_trades': wait,
+        'wait_hit_rate': float((pd.Series(wait_closed)>0).mean()) if len(wait_closed)>=1 else 0.0,
+    }
+    return summary
+
+if __name__ == '__main__':
+    current = evaluate('current')
+    rr_cfg = sig_engine.EngineConfig(**{**sig_engine.DEFAULT_CFG.__dict__, 'risk_reward_targets': (1.0,2.0,3.0)})
+    rr = evaluate('revert_rr_targets', cfg=rr_cfg)
+    norm = evaluate('revert_factor_normalization', normaliser=simple_clip_normalise)
+    regime = evaluate('revert_regime_classifier', classifier=old_classify, reg_conf=old_regime_confidence)
+    print(json.dumps([current, rr, norm, regime], indent=2))
