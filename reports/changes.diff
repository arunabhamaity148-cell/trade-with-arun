+from __future__ import annotations
+import asyncio, csv, zipfile, json, logging, urllib.request
+from datetime import datetime, timezone
+from pathlib import Path
+import pandas as pd
+
+logging.disable(logging.CRITICAL)
+
+from twa.config import Settings
+from twa.models.types import Candle, Timeframe
+from twa.backtest.replay import simulate
+from twa.research.benchmarking import BenchmarkRunner, BenchmarkConfig, PRODUCTION_ENGINE_NO_NEWS_GUARD
+from twa.research.utils import max_drawdown, sharpe_like
+
+DATA_DIR=Path('/home/user/data/binance_months')
+month='2025-05'
+path=DATA_DIR/f'BTCUSDT-1h-{month}.zip'
+if not path.exists():
+    urllib.request.urlretrieve(f'https://data.binance.vision/data/futures/um/monthly/klines/BTCUSDT/1h/BTCUSDT-1h-{month}.zip', path)
+
+candles=[]
+with zipfile.ZipFile(path) as z:
+    with z.open(z.namelist()[0]) as f:
+        reader=csv.DictReader((line.decode() for line in f))
+        for row in reader:
+            ot=datetime.fromtimestamp(int(row['open_time'])/1000,tz=timezone.utc)
+            ct=datetime.fromtimestamp(int(row['close_time'])/1000,tz=timezone.utc)
+            candles.append(Candle(symbol='BTCUSDT',exchange='binance',timeframe=Timeframe.H1,open_time=ot,close_time=ct,open=float(row['open']),high=float(row['high']),low=float(row['low']),close=float(row['close']),volume=float(row['volume'])))
+candles=candles[:720]
+result=simulate(candles, Timeframe.H1, factor_overrides_list=[{}]*len(candles), settings=Settings(_env_file=None, risk_cooldown_s=0))
+closed=[t.pnl_bps for t in result.trades if t.exit_price is not None]
+series=pd.Series(closed, dtype=float)
+sim_metrics={
+  'window':[candles[0].open_time.isoformat(), candles[-1].open_time.isoformat()],
+  'trades': result.total_trades,
+  'edge_per_trade_bps': float(result.expectancy_bps),
+  'hit_rate_actual': float((series>0).mean()) if len(series) else 0.0,
+  'drawdown_bps': float(abs(max_drawdown(series))) if len(series) else 0.0,
+  'sharpe_like': sharpe_like(series),
+}
+
+async def bench():
+    runner=BenchmarkRunner(Settings(_env_file=None, data_dir=Path('/tmp/twa-bench')))
+    try:
+        report=await runner.run(symbol='BTCUSDT', timeframe=Timeframe.H1, candles=candles, config=BenchmarkConfig(walk_forward_train_bars=120, walk_forward_test_bars=40, walk_forward_step_bars=40, walk_forward_folds=5, walk_forward_embargo_bars=4))
+        return report.model_dump()
+    finally:
+        await runner.close()
+bench_report=asyncio.run(bench())
+prod = next(row for row in bench_report['strategies'] if row['name']==PRODUCTION_ENGINE_NO_NEWS_GUARD)
+out={'simulate':sim_metrics,'benchmark_report':bench_report,'production_walk_forward':prod}
+Path('/home/user/work/tmp_final_metrics.json').write_text(json.dumps(out, indent=2), encoding='utf-8')
+print('done')
