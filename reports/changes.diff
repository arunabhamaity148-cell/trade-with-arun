+from __future__ import annotations
+import csv, zipfile, json, logging, urllib.request
+from collections import Counter, defaultdict
+from datetime import datetime, timezone
+from pathlib import Path
+import pandas as pd
+
+logging.disable(logging.CRITICAL)
+
+from twa.models.types import Candle, Timeframe
+from twa.features.engineering import compute_all
+from twa.regime.classifier import classify, regime_confidence, assign_weights
+from twa.signal.engine import compute_signal, build_factor_vector, normalise_factor
+from twa.backtest.replay import simulate
+from twa.config import Settings
+
+month='2025-05'
+DATA_DIR=Path('/home/user/data/binance_months')
+path=DATA_DIR/f'BTCUSDT-1h-{month}.zip'
+if not path.exists():
+    urllib.request.urlretrieve(f'https://data.binance.vision/data/futures/um/monthly/klines/BTCUSDT/1h/BTCUSDT-1h-{month}.zip', path)
+
+candles=[]
+with zipfile.ZipFile(path) as z:
+    name=z.namelist()[0]
+    with z.open(name) as f:
+        reader=csv.DictReader((line.decode() for line in f))
+        for row in reader:
+            ot=datetime.fromtimestamp(int(row['open_time'])/1000,tz=timezone.utc)
+            ct=datetime.fromtimestamp(int(row['close_time'])/1000,tz=timezone.utc)
+            candles.append(Candle(symbol='BTCUSDT',exchange='binance',timeframe=Timeframe.H1,open_time=ot,close_time=ct,open=float(row['open']),high=float(row['high']),low=float(row['low']),close=float(row['close']),volume=float(row['volume'])))
+
+regimes=Counter()
+signals=[]
+for i in range(60, len(candles)-16):
+    window=candles[:i]
+    feats=compute_all(window)
+    reg=classify(feats)
+    regimes[reg.value]+=1
+    sig=compute_signal(window, Timeframe.H1, {}, reg, regime_confidence(feats, reg))
+    if sig is not None:
+        signals.append({
+            'time': candles[i].open_time.isoformat(),
+            'regime': reg.value,
+            'side': sig.side.value,
+            'raw_conf': sig.raw_confidence,
+            'entry_state': sig.entry_state.value,
+            'score_sum': sum(fc.contribution for fc in sig.factor_contributions),
+            'factors': {fc.name: {'raw':fc.raw_value,'norm':fc.norm_value,'w':fc.weight,'c':fc.contribution} for fc in sig.factor_contributions},
+        })
+
+result=simulate(candles[:720], Timeframe.H1, factor_overrides_list=[{}]*720, settings=Settings(_env_file=None, risk_cooldown_s=0))
+# crude match by detection/open time
+sig_map={s['time']:s for s in signals}
+by_reg=defaultdict(list)
+by_side=defaultdict(list)
+by_reg_side=defaultdict(list)
+for t in result.trades:
+    sig=sig_map.get(t.entry_time.isoformat())
+    reg=sig['regime'] if sig else 'unknown'
+    side=sig['side'] if sig else t.side.value
+    by_reg[reg].append(t.pnl_bps)
+    by_side[side].append(t.pnl_bps)
+    by_reg_side[(reg,side)].append(t.pnl_bps)
+
+summary={
+    'regime_counts_all_bars': regimes,
+    'signal_counts_by_regime': Counter(s['regime'] for s in signals),
+    'signal_counts_by_side': Counter(s['side'] for s in signals),
+    'trade_perf_by_regime': {k:{'trades':len(v),'mean_bps':sum(v)/len(v),'hit_rate':sum(1 for x in v if x>0)/len(v)} for k,v in by_reg.items()},
+    'trade_perf_by_side': {k:{'trades':len(v),'mean_bps':sum(v)/len(v),'hit_rate':sum(1 for x in v if x>0)/len(v)} for k,v in by_side.items()},
+    'trade_perf_by_regime_side': {f'{k[0]}|{k[1]}':{'trades':len(v),'mean_bps':sum(v)/len(v),'hit_rate':sum(1 for x in v if x>0)/len(v)} for k,v in by_reg_side.items()},
+}
+Path('/home/user/work/tmp_diagnose_2025_05.json').write_text(json.dumps(summary, indent=2), encoding='utf-8')
+print('done')
