+from __future__ import annotations
+import csv, zipfile, urllib.request, os, logging, json
+from datetime import datetime, timezone
+from pathlib import Path
+import pandas as pd
+
+logging.disable(logging.CRITICAL)
+
+from twa.config import Settings
+from twa.models.types import Candle, Timeframe
+from twa.backtest.replay import simulate
+from twa.research.utils import max_drawdown, sharpe_like
+
+DATA_DIR = Path('/home/user/data/binance_months')
+DATA_DIR.mkdir(parents=True, exist_ok=True)
+
+def month_iter():
+    for y in [2025, 2026]:
+        max_m = 12 if y < 2026 else 6
+        for m in range(1, max_m+1):
+            yield f'{y}-{m:02d}'
+
+def fetch(month:str)->Path:
+    out = DATA_DIR / f'BTCUSDT-1h-{month}.zip'
+    if out.exists():
+        return out
+    url=f'https://data.binance.vision/data/futures/um/monthly/klines/BTCUSDT/1h/BTCUSDT-1h-{month}.zip'
+    urllib.request.urlretrieve(url,out)
+    return out
+
+def load(path:Path):
+    candles=[]
+    with zipfile.ZipFile(path) as z:
+        name=z.namelist()[0]
+        with z.open(name) as f:
+            reader=csv.DictReader((line.decode() for line in f))
+            for row in reader:
+                ot=datetime.fromtimestamp(int(row['open_time'])/1000,tz=timezone.utc)
+                ct=datetime.fromtimestamp(int(row['close_time'])/1000,tz=timezone.utc)
+                candles.append(Candle(symbol='BTCUSDT',exchange='binance',timeframe=Timeframe.H1,open_time=ot,close_time=ct,open=float(row['open']),high=float(row['high']),low=float(row['low']),close=float(row['close']),volume=float(row['volume'])))
+    return candles[:720] if len(candles)>=720 else candles
+
+rows=[]
+for month in month_iter():
+    try:
+        path=fetch(month)
+        candles=load(path)
+        result=simulate(candles, Timeframe.H1, factor_overrides_list=[{}]*len(candles), settings=Settings(_env_file=None, risk_cooldown_s=0))
+        closed=[t.pnl_bps for t in result.trades if t.exit_price is not None]
+        ser=pd.Series(closed,dtype=float)
+        rows.append({
+            'month':month,
+            'bars':len(candles),
+            'trades':result.total_trades,
+            'edge':float(result.expectancy_bps),
+            'hit_rate':float(result.win_rate() or 0.0),
+            'drawdown':float(abs(max_drawdown(ser))) if len(ser) else 0.0,
+            'sharpe':sharpe_like(ser),
+            'note':result.note,
+        })
+    except Exception as e:
+        rows.append({'month':month,'error':str(e)})
+Path('/home/user/work/tmp_scan_months_results.json').write_text(json.dumps(rows, indent=2), encoding='utf-8')
+print('done', len(rows))
