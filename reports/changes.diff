--- /home/user/pristine/tmp_scan_fixed_months.py	1970-01-01 00:00:00.000000000 +0000
+++ /home/user/work/tmp_scan_fixed_months.py	2026-07-18 11:22:11.004270486 +0000
@@ -0,0 +1,95 @@
+from __future__ import annotations
+import csv, zipfile, urllib.request, logging, json, copy
+from datetime import datetime, timezone
+from pathlib import Path
+import pandas as pd
+
+logging.disable(logging.CRITICAL)
+
+from twa.config import Settings
+from twa.models.types import Candle, Timeframe, RegimeLabel
+import twa.backtest.replay as replay
+import twa.regime.classifier as regime_mod
+from twa.research.utils import max_drawdown, sharpe_like
+
+DATA_DIR = Path('/home/user/data/binance_months')
+DATA_DIR.mkdir(parents=True, exist_ok=True)
+
+orig_weights = copy.deepcopy(regime_mod.FACTOR_WEIGHTS)
+orig_norm = copy.deepcopy(regime_mod.WEIGHTS_NORMALISED)
+
+weights = copy.deepcopy(orig_weights)
+for k in ['trend_strength_48','log_return_16','obv_slope_48','obi']:
+    weights[RegimeLabel.TREND_DOWN][k] = abs(weights[RegimeLabel.TREND_DOWN][k])
+# stressed: lean on signed directional features when cross-venue factors absent
+weights[RegimeLabel.STRESSED].update({
+    'funding': 0.0,
+    'basis': 0.0,
+    'oi_delta': 0.0,
+    'trend_strength_48': 0.20,
+    'log_return_16': 0.15,
+    'obv_slope_48': 0.10,
+    'obi': 0.05,
+    'volume_zscore_96': 0.05,
+    'realised_vol_30': -0.05,
+})
+# volatile: similar fallback when microstructure overrides absent
+weights[RegimeLabel.VOLATILE].update({
+    'funding': 0.0,
+    'basis': 0.0,
+    'oi_delta': 0.0,
+    'trend_strength_48': 0.25,
+    'log_return_16': 0.15,
+    'obv_slope_48': 0.10,
+    'obi': 0.10,
+    'volume_zscore_96': 0.05,
+    'realised_vol_30': -0.05,
+})
+
+def renorm(d):
+    s=sum(abs(v) for v in d.values())
+    return {k:float(v/s) for k,v in d.items()}
+
+regime_mod.FACTOR_WEIGHTS.clear(); regime_mod.FACTOR_WEIGHTS.update(weights)
+regime_mod.WEIGHTS_NORMALISED.clear(); regime_mod.WEIGHTS_NORMALISED.update({r:renorm(w) for r,w in weights.items()})
+
+def month_iter():
+    for y in [2025, 2026]:
+        max_m = 12 if y < 2026 else 6
+        for m in range(1, max_m+1):
+            yield f'{y}-{m:02d}'
+
+def fetch(month:str)->Path:
+    out = DATA_DIR / f'BTCUSDT-1h-{month}.zip'
+    if out.exists(): return out
+    urllib.request.urlretrieve(f'https://data.binance.vision/data/futures/um/monthly/klines/BTCUSDT/1h/BTCUSDT-1h-{month}.zip', out)
+    return out
+
+def load(path:Path):
+    candles=[]
+    with zipfile.ZipFile(path) as z:
+        name=z.namelist()[0]
+        with z.open(name) as f:
+            reader=csv.DictReader((line.decode() for line in f))
+            for row in reader:
+                ot=datetime.fromtimestamp(int(row['open_time'])/1000,tz=timezone.utc)
+                ct=datetime.fromtimestamp(int(row['close_time'])/1000,tz=timezone.utc)
+                candles.append(Candle(symbol='BTCUSDT',exchange='binance',timeframe=Timeframe.H1,open_time=ot,close_time=ct,open=float(row['open']),high=float(row['high']),low=float(row['low']),close=float(row['close']),volume=float(row['volume'])))
+    return candles[:720] if len(candles)>=720 else candles
+
+rows=[]
+for month in month_iter():
+    try:
+        candles=load(fetch(month))
+        result=replay.simulate(candles, Timeframe.H1, factor_overrides_list=[{}]*len(candles), settings=Settings(_env_file=None, risk_cooldown_s=0))
+        closed=[t.pnl_bps for t in result.trades if t.exit_price is not None]
+        ser=pd.Series(closed,dtype=float)
+        rows.append({'month':month,'trades':result.total_trades,'edge':float(result.expectancy_bps),'hit_rate_actual':float((ser>0).mean()) if len(ser) else 0.0,'drawdown':float(abs(max_drawdown(ser))) if len(ser) else 0.0,'sharpe':sharpe_like(ser)})
+    except Exception as e:
+        rows.append({'month':month,'error':str(e)})
+
+Path('/home/user/work/tmp_scan_fixed_months_results.json').write_text(json.dumps(rows, indent=2), encoding='utf-8')
+# restore
+regime_mod.FACTOR_WEIGHTS.clear(); regime_mod.FACTOR_WEIGHTS.update(orig_weights)
+regime_mod.WEIGHTS_NORMALISED.clear(); regime_mod.WEIGHTS_NORMALISED.update(orig_norm)
+print('done')
