# =====================================================
# TRADE WITH ARUN - environment configuration template
# Copy to .env and edit. All values are optional; defaults
# permit running in "paper" mode without external credentials.
# =====================================================

# --- General ---
TWA_ENV=paper
TWA_LOG_LEVEL=INFO
TWA_DATA_DIR=./data
TWA_TIMEZONE=UTC

# --- Symbols / timeframe ---
TWA_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT
TWA_TIMEFRAME=1h
TWA_LOOKBACK_BARS=500

# --- Exchanges (Binance / Bybit / Coinbase free public endpoints, no key required) ---
TWA_EXCHANGES=binance,bybit,coinbase
TWA_HTTP_TIMEOUT_S=15
TWA_HTTP_CONCURRENCY=8
TWA_WS_ENABLED=true

# --- News Guard ---
TWA_NEWS_ENABLED=true
TWA_NEWS_REFRESH_S=180
TWA_NEWS_SOURCES=cryptopanic,rss
TWA_CRYPTOPANIC_PUBLIC_KEY=        # optional; free public key from cryptopanic.com

# --- Telegram ---
TWA_TELEGRAM_ENABLED=false
TWA_TELEGRAM_BOT_TOKEN=             # required if enabled
TWA_TELEGRAM_CHAT_ID=               # required if enabled
TWA_TELEGRAM_MIN_INTERVAL_S=120

# --- ML calibration (optional) ---
TWA_ML_ENABLED=false
TWA_ML_MODEL_PATH=./models/calibrator.joblib

# --- Monitoring ---
TWA_HEARTBEAT_S=30
TWA_METRICS_PORT=9100

# --- Risk ---
TWA_RISK_MAX_CONFIDENCE=0.95
TWA_RISK_NEWS_DAMPEN=0.5
TWA_RISK_COOLDOWN_S=900
